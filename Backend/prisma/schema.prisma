generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("agent")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notificationLogs NotificationLog[]
  // Prospects owned by this user
  ownedProspects   Prospect[]

  @@index([role])
}

model Prospect {
  id               String                @id @default(cuid())
  name             String
  school           String
  role             String?
  email            String?
  phone            String?
  source           String                @default("Direct")
  stage            String                @default("Cold")
  lastContactDate  DateTime?
  nextFollowUpDate DateTime?
  completed        Boolean               @default(false)
  completedAt      DateTime?
  deletedAt        DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  // Optional owner relationship: a `User` responsible for this prospect
  owner            User?                 @relation(fields: [ownerId], references: [id])
  ownerId          String?
  lastNotifiedAt   DateTime?

  notes            ProspectNote[]
  checklistItems   OnboardingChecklist[]
  auditLogs        AuditLog[]

  @@index([stage, createdAt])
  @@index([nextFollowUpDate])
  @@index([deletedAt])
  @@index([completed])
}

model AuditLog {
  id         String   @id @default(cuid())
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  prospectId String
  action     String
  actorId    String
  actorRole  String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([prospectId, createdAt])
  @@index([action, createdAt])
}

model ProspectNote {
  id         String   @id @default(cuid())
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  prospectId String
  content    String
  createdAt  DateTime @default(now())

  @@index([prospectId, createdAt])
}

model OnboardingChecklist {
  id          String   @id @default(cuid())
  prospect    Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  prospectId  String
  stepNumber  Int
  title       String
  description String?
  assignee    String?
  status      String   @default("todo")
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([prospectId, stepNumber])
  @@index([prospectId, status])
}

model NotificationLog {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String   @default("notification") // e.g., "overdue_prospects", "milestone", etc.
  title     String
  message   String
  metadata  Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
  @@index([type, createdAt])
}
