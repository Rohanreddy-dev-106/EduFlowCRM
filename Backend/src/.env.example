PORT=5000
DATABASE_URL=mysql://root:password@127.0.0.1:3306/kalnet_crm
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Email Configuration
EMAIL_FROM=noreply@crm.com
FRONTEND_URL=http://localhost:3000

# SMTP Configuration (production)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Gmail Configuration (alternative to SMTP)
# GMAIL_USER=your-email@gmail.com
# GMAIL_PASS=your-app-password

# Notification Settings
ENABLE_NOTIFICATIONS=true
# Cron schedule for overdue notifications (default: 9 AM daily)
# Format: minute hour day month dayOfWeek (0 9 * * * = 9 AM every day)
NOTIFICATION_SCHEDULE=0 9 * * *

# Sentry (Error tracking)
# SENTRY_DSN=https://...
# SENTRY_TRACES_SAMPLE_RATE=0.1
